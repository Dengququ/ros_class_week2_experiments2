<?xml version="1.0"?>
<robot name="simple_robot" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- ==================== 全局参数 ==================== -->
  <!-- 底盘 -->
  <xacro:property name="base_length" value="0.4"/>
  <xacro:property name="base_width"  value="0.3"/>
  <xacro:property name="base_height" value="0.1"/>

  <!-- 驱动轮 -->
  <xacro:property name="wheel_radius" value="0.06"/>
  <xacro:property name="wheel_length" value="0.04"/>
  <xacro:property name="wheel_separation" value="0.34"/>
  <xacro:property name="wheel_z_offset" value="-0.05"/>

  <!-- 万向轮 -->
  <xacro:property name="caster_radius" value="0.03"/>

  <!-- 激光雷达 -->
  <xacro:property name="lidar_radius" value="0.05"/>
  <xacro:property name="lidar_height" value="0.04"/>

  <!-- ==================== 底盘 ==================== -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
      <material name="blue">
        <color rgba="0.0 0.0 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="${base_length} ${base_width} ${base_height}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0"
               iyy="0.1" iyz="0.0" izz="0.1"/>
    </inertial>
  </link>

  <!-- ==================== 驱动轮宏 ==================== -->
  <!-- 参数：name=左/右名称前缀，y_pos=Y轴位置（正为左，负为右） -->
  <xacro:macro name="drive_wheel" params="name y_pos">

    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
        <material name="black">
          <color rgba="0.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${wheel_radius}" length="${wheel_length}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.01" ixy="0.0" ixz="0.0"
                 iyy="0.01" iyz="0.0" izz="0.01"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="revolute">
      <parent link="base_link"/>
      <child link="${name}_link"/>
      <origin xyz="0.0 ${y_pos} ${wheel_z_offset}" rpy="1.5708 0.0 0.0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-1e9" upper="1e9" effort="10.0" velocity="10.0"/>
    </joint>

    <!-- 驱动轮摩擦力 -->
    <gazebo reference="${name}_link">
      <mu1>1.0</mu1>
      <mu2>1.0</mu2>
    </gazebo>

  </xacro:macro>

  <!-- 调用轮子宏：左轮和右轮 -->
  <xacro:drive_wheel name="wheel_left"  y_pos="${ wheel_separation / 2}"/>
  <xacro:drive_wheel name="wheel_right" y_pos="${-wheel_separation / 2}"/>

  <!-- ==================== 万向轮 ==================== -->
  <link name="caster_link">
    <visual>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
      <material name="gray">
        <color rgba="0.5 0.5 0.5 1.0"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <sphere radius="${caster_radius}"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="0.1"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0"
               iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
  </link>

  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_link"/>
    <origin xyz="${-base_length/2 + caster_radius} 0.0 ${-base_height/2 - caster_radius}" rpy="0.0 0.0 0.0"/>
  </joint>

  <gazebo reference="caster_link">
    <mu1>0.0</mu1>
    <mu2>0.0</mu2>
  </gazebo>

  <!-- ==================== 激光雷达宏 ==================== -->
  <xacro:macro name="lidar_sensor" params="name parent_link x_pos y_pos z_pos">

    <link name="${name}_link">
      <visual>
        <geometry>
          <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
        </geometry>
        <material name="black">
          <color rgba="0.0 0.0 0.0 1.0"/>
        </material>
      </visual>
      <collision>
        <geometry>
          <cylinder radius="${lidar_radius}" length="${lidar_height}"/>
        </geometry>
      </collision>
      <inertial>
        <mass value="0.1"/>
        <inertia ixx="0.001" ixy="0.0" ixz="0.0"
                 iyy="0.001" iyz="0.0" izz="0.001"/>
      </inertial>
    </link>

    <joint name="${name}_joint" type="fixed">
      <parent link="${parent_link}"/>
      <child link="${name}_link"/>
      <origin xyz="${x_pos} ${y_pos} ${z_pos}" rpy="0.0 0.0 0.0"/>
    </joint>

  </xacro:macro>

  <!-- 调用激光雷达宏：固定在底盘顶部中央 -->
  <xacro:lidar_sensor name="lidar"
                      parent_link="base_link"
                      x_pos="0.0"
                      y_pos="0.0"
                      z_pos="${base_height/2 + lidar_height/2}"/>

  <!-- ==================== 差速驱动插件 ==================== -->
  <gazebo>
    <plugin name="differential_drive_controller"
            filename="libgazebo_ros_diff_drive.so">
      <leftJoint>wheel_left_joint</leftJoint>
      <rightJoint>wheel_right_joint</rightJoint>
      <wheelSeparation>${wheel_separation}</wheelSeparation>
      <wheelDiameter>${wheel_radius * 2}</wheelDiameter>
      <maxWheelTorque>20</maxWheelTorque>
      <maxWheelAcceleration>1.0</maxWheelAcceleration>
      <commandTopic>/cmd_vel</commandTopic>
      <odometryTopic>/odom</odometryTopic>
      <odometryFrame>odom</odometryFrame>
      <robotBaseFrame>base_link</robotBaseFrame>
      <publishWheelTF>false</publishWheelTF>
      <publishOdomTF>true</publishOdomTF>
      <publishWheelJointState>true</publishWheelJointState>
    </plugin>
  </gazebo>

</robot>
